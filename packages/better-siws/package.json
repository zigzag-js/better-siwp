{
  "name": "@zig-zag/better-siwp",
  "version": "0.1.1",
  "description": "Sign-In with Polkadot (SIWP) plugin for Better Auth - Polkadot wallet authentication made simple",
  "author": "Yogesh Kumar (https://github.com/itsyogesh)",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts",
      "import": "./client.js",
      "require": "./client.js"
    }
  },
  "files": [
    "dist",
    "client.js",
    "client.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@talismn/siws": "^1.0.0"
  },
  "peerDependencies": {
    "better-auth": "^1.5.0",
    "better-call": "^1.3.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "better-auth": "^1.5.6",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1",
    "zod": "^4.3.6"
  },
  "keywords": [
    "better-auth",
    "authentication",
    "polkadot",
    "substrate",
    "siwp",
    "siws",
    "web3",
    "wallet",
    "sign-in-with-polkadot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zigzag-js/better-siwp"
  },
  "bugs": {
    "url": "https://github.com/zigzag-js/better-siwp/issues"
  },
  "homepage": "https://github.com/zigzag-js/better-siwp#readme"
}
